{
  "entities": {
    "KBContent": {
      "title": "Knowledge Base Content",
      "description": "Information chunks that ground the AI assistant answers.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The actual text content." },
        "source": { "type": "string", "description": "The title or source name of the content." },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["content", "source", "createdAt", "createdBy"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stored user information and roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "parent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat conversation.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "sender", "createdAt"]
    }
  },
  "firestore": {
    "/kb_content/{contentId}": {
      "schema": "KBContent",
      "description": "Admin-uploaded knowledge base for AI grounding."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a specific chat session."
    }
  }
}
