rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function existingData() {
      return resource.data;
    }

    function incomingData() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Entity Validations ---
    function isValidKBContent(data) {
      return data.keys().hasAll(['content', 'source', 'createdAt', 'createdBy']) &&
             data.keys().size() == 4 &&
             data.content is string && data.content.size() <= 10000 &&
             data.source is string && data.source.size() <= 200 &&
             data.createdAt == request.time &&
             data.createdBy == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'parent'] &&
             data.createdAt is timestamp;
    }

    // --- Collections ---

    // Knowledge Base Content
    match /kb_content/{contentId} {
      allow read: if true; 
      allow create: if true;
      allow update: if false; 
      allow delete: if true;
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incomingData());
      allow update: if isAdmin();
      allow update: if isSignedIn() && request.auth.uid == userId && 
                    incomingData().diff(existingData()).affectedKeys().hasOnly(['email']);
    }

    // Chats and Messages (Secure List Queries enforced)
    match /chats/{chatId} {
      allow get: if isSignedIn() && (existingData().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incomingData().userId == request.auth.uid;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && 
          (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && 
          (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
